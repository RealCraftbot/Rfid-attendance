generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
}

enum CheckType {
  check_in
  check_out
  bus_pickup_home
  bus_drop_school
  bus_pickup_school
  bus_drop_home
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BusStatus {
  WAITING
  ON_BUS
  AT_SCHOOL
  ON_RETURN
  HOME
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String   @unique
  phone     String?
  address   String?
  status    SubscriptionStatus @default(TRIAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  students      Student[]
  devices       Device[]
  classrooms    Classroom[]
  attendance    AttendanceRecord[]
  busRoutes     BusRoute[]

  @@index([slug])
  @@index([status])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(TEACHER)
  orgId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions  Session[]

  @@index([orgId])
  @@index([email])
  @@index([role])
}

model Student {
  id              String   @id @default(cuid())
  rfidUid         String
  name            String
  grade           String?
  classroomId     String?
  orgId           String
  isActive        Boolean  @default(true)
  dateOfBirth     DateTime?
  guardianName    String?
  guardianPhone    String?
  guardianEmail    String?
  currentStatus   CheckType?
  lastSeen        DateTime?
  usesSchoolBus   Boolean  @default(false)
  busRouteId      String?
  busStatus       BusStatus?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  classroom   Classroom?       @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  busRoute    BusRoute?       @relation(fields: [busRouteId], references: [id])
  attendance  AttendanceRecord[]

  @@unique([orgId, rfidUid])
  @@index([orgId])
  @@index([rfidUid])
  @@index([classroomId])
  @@index([busRouteId])
}

model Classroom {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  grade     String?
  teacherId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([orgId, name])
  @@index([orgId])
}

model BusRoute {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  routeCode String
  morningStart String?
  eveningEnd   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  students Student[]
  stops    BusStop[]

  @@unique([orgId, routeCode])
  @@index([orgId])
}

model BusStop {
  id        String   @id @default(cuid())
  name      String
  address   String?
  routeId   String
  order     Int
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  route BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}

model Device {
  id           String    @id @default(cuid())
  deviceId     String
  name         String
  secretKey    String
  orgId        String
  location     String?
  locationType String    @default("gate")
  isActive     Boolean   @default(true)
  batteryLevel Int?
  lastSeen     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, deviceId])
  @@index([orgId])
  @@index([deviceId])
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  studentId   String
  studentName String
  orgId       String
  deviceId    String
  checkType   CheckType @default(check_in)
  busRouteId  String?
  busStopId   String?
  scanTime    DateTime  @default(now())
  idempotencyKey String  @unique @default(cuid())
  createdAt   DateTime  @default(now())

  student  Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([orgId])
  @@index([scanTime])
  @@index([orgId, scanTime])
  @@index([deviceId, scanTime])
  @@index([busRouteId])
}

model Session {
  id           String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}
