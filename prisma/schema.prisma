generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  BURSAR
  PARENT
}

enum ParentRelationship {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum CheckType {
  check_in
  check_out
  bus_pickup_home
  bus_drop_school
  bus_pickup_school
  bus_drop_home
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BusStatus {
  WAITING
  ON_BUS_TO_SCHOOL
  AT_SCHOOL
  ON_BUS_TO_HOME
  HOME
}

enum AcademicTerm {
  FIRST
  SECOND
  THIRD
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum GradeLevel {
  A
  B
  C
  D
  E
  F
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String   @unique
  phone     String?
  address   String?
  logoUrl   String?
  status    SubscriptionStatus @default(TRIAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  students          Student[]
  devices           Device[]
  classrooms        Classroom[]
  attendance        AttendanceRecord[]
  teacherAttendance TeacherAttendance[]
  busRoutes         BusRoute[]
  feeStructures     FeeStructure[]
  invoices          Invoice[]
  bankAccounts      BankAccount[]
  paymentTransactions PaymentTransaction[]
  timetables        Timetable[]
  parents           Parent[]
  teachers          Teacher[]
  academicSessions  AcademicSession[]
  messages          Message[]

  @@index([slug])
  @@index([status])
}

model AcademicSession {
  id            String   @id @default(cuid())
  orgId         String
  name          String   // e.g., "2024/2025"
  term          AcademicTerm @default(FIRST)
  startDate     DateTime
  endDate       DateTime
  schoolOpenTime String   @default("07:30") // HH:MM format
  schoolCloseTime String  @default("15:00") // HH:MM format
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name, term])
  @@index([orgId])
  @@index([isActive])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  role            Role      @default(TEACHER)
  orgId           String?
  imageUrl        String?
  emailVerified   DateTime?
  isActive        Boolean   @default(true)  // Whether user account is active
  passwordSet     Boolean   @default(false)  // Whether user has set their own password
  invitationToken String?  // Token sent to user for password setup
  invitationSentAt DateTime?  // When invitation was sent
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions  Session[]
  parentProfile Parent?

  @@index([orgId])
  @@index([email])
  @@index([role])
  @@index([invitationToken])
  @@index([isActive])
}

model Teacher {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  employeeId    String?
  subject       String?
  qualification String?
  address       String?
  rfidUid      String?
  orgId         String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org          Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  classrooms   Classroom[]
  timetables   Timetable[]
  attendance   TeacherAttendance[]
  grades       Grade[]

  @@unique([orgId, rfidUid])
  @@index([orgId])
  @@index([email])
  @@index([rfidUid])
}

model Parent {
  id            String   @id @default(cuid())
  userId       String   @unique
  name         String
  email        String
  phone        String?
  relationship ParentRelationship @default(GUARDIAN)
  address      String?
  idNumber     String?  // NIN, Voter's Card, etc.
  orgId        String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  students  StudentParent[]

  @@index([orgId])
  @@index([userId])
  @@index([email])
}

model StudentParent {
  id            String   @id @default(cuid())
  studentId     String
  parentId      String
  relationship  ParentRelationship @default(GUARDIAN)
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([studentId])
  @@index([parentId])
}

model Student {
  id              String   @id @default(cuid())
  rfidUid         String
  name            String
  grade           String?
  classroomId     String?
  orgId           String
  isActive        Boolean  @default(true)
  dateOfBirth     DateTime?
  guardianName    String?
  guardianPhone   String?
  guardianEmail   String?
  currentStatus   CheckType?
  lastSeen        DateTime?
  usesSchoolBus   Boolean  @default(false)
  busRouteId      String?
  busStatus       BusStatus?
  admissionNumber String?
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  classroom   Classroom?       @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  busRoute    BusRoute?       @relation(fields: [busRouteId], references: [id])
  attendance  AttendanceRecord[]
  invoices    Invoice[]
  grades      Grade[]
  parents     StudentParent[]

  @@unique([orgId, rfidUid])
  @@index([orgId])
  @@index([rfidUid])
  @@index([classroomId])
  @@index([busRouteId])
}

model Classroom {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  grade     String?
  teacherId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org               Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teacher          Teacher?            @relation(fields: [teacherId], references: [id])
  students          Student[]
  teacherAttendance TeacherAttendance[]
  timetables       Timetable[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([teacherId])
}

model TeacherAttendance {
  id          String    @id @default(cuid())
  teacherId   String
  classroomId String
  orgId       String
  deviceId    String
  checkType   CheckType @default(check_in)
  scanTime    DateTime  @default(now())
  idempotencyKey String  @unique @default(cuid())
  createdAt   DateTime  @default(now())

  teacher   Teacher      @relation(fields: [teacherId], references: [id])
  classroom Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([classroomId])
  @@index([orgId])
  @@index([scanTime])
  @@index([orgId, scanTime])
}

model BusRoute {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  routeCode String
  morningStart String?
  eveningEnd   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  students Student[]
  stops    BusStop[]

  @@unique([orgId, routeCode])
  @@index([orgId])
}

model BusStop {
  id        String   @id @default(cuid())
  name      String
  address   String?
  routeId   String
  order     Int
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  route BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}

model Device {
  id           String    @id @default(cuid())
  deviceId     String
  name         String
  secretKey    String
  orgId        String
  location     String?
  locationType String    @default("gate")
  isActive     Boolean   @default(true)
  batteryLevel Int?
  lastSeen     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, deviceId])
  @@index([orgId])
  @@index([deviceId])
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  studentId   String
  studentName String
  orgId       String
  deviceId    String
  checkType   CheckType @default(check_in)
  busRouteId  String?
  busStopId   String?
  scanTime    DateTime  @default(now())
  idempotencyKey String  @unique @default(cuid())
  createdAt   DateTime  @default(now())

  student  Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([orgId])
  @@index([scanTime])
  @@index([orgId, scanTime])
  @@index([deviceId, scanTime])
  @@index([busRouteId])
}

model FeeStructure {
  id          String   @id @default(cuid())
  name        String
  description String?
  amount      Float
  dueDate    DateTime
  academicYear String
  term       Int
  isActive   Boolean  @default(true)
  orgId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([orgId])
  @@index([academicYear, term])
}

model Invoice {
  id              String   @id @default(cuid())
  studentId       String
  feeStructureId  String
  orgId          String
  amount         Float
  paidAmount     Float    @default(0)
  status         PaymentStatus @default(PENDING)
  dueDate        DateTime
  paidDate       DateTime?
  academicYear   String
  term           Int
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payments     PaymentTransaction[]

  @@index([studentId])
  @@index([orgId])
  @@index([status])
  @@index([academicYear, term])
}

model BankAccount {
  id            String   @id @default(cuid())
  accountName   String
  accountNumber String
  bankName      String
  bankCode      String?
  accountType   String   @default("current") // current, savings, etc
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  orgId         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([isActive])
}

enum TransactionStatus {
  PENDING
  PROCESSING
  VERIFIED
  REJECTED
  COMPLETED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CHEQUE
  POS
  ONLINE
}

model PaymentTransaction {
  id                String   @id @default(cuid())
  invoiceId         String
  orgId             String
  amount            Float
  paymentMethod     PaymentMethod @default(BANK_TRANSFER)
  transactionStatus TransactionStatus @default(PENDING)
  proofOfPaymentUrl String?  // URL to uploaded proof (receipt/screenshot)
  paidByUserId      String?  // Parent who made the payment
  paidByName        String?  // Name of payer
  paidByEmail       String?  // Email of payer
  paidByPhone       String?  // Phone of payer
  transactionDate   DateTime @default(now())
  transactionRef    String?  // Bank transaction reference
  notes             String?  // Notes from payer
  
  // Approval workflow
  reviewedById      String?  // Bursar/Admin who reviewed
  reviewedByName    String?  // Name of reviewer
  reviewedAt        DateTime? // When reviewed
  reviewNotes       String?  // Notes from reviewer
  rejectionReason   String?  // Reason if rejected
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([orgId])
  @@index([transactionStatus])
  @@index([transactionDate])
}

model Grade {
  id              String   @id @default(cuid())
  studentId       String
  subject         String
  academicYear    String
  term            Int
  testScore       Float?
  examScore       Float?
  totalScore     Float?
  grade           GradeLevel?
  remarks         String?
  teacherId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([studentId, subject, academicYear, term])
  @@index([studentId])
  @@index([teacherId])
  @@index([academicYear, term])
}

model Session {
  id           String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Message {
  id          String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  orgId      String
  isRead     Boolean  @default(false)
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([senderId])
  @@index([receiverId])
  @@index([orgId, receiverId])
  @@index([createdAt])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Timetable {
  id          String    @id @default(cuid())
  orgId       String
  day         String    // Monday, Tuesday, etc.
  period      Float     // 1, 2, 2.5, 3, etc. (allows breaks between periods)
  periodLabel String?   // "1st Period", "Short Break", "Lunch"
  subject     String?
  teacherId   String?
  classroomId String?
  startTime   String    // HH:MM format
  endTime     String    // HH:MM format
  isBreak     Boolean   @default(false)
  breakType   String?   // "short", "long", "lunch"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  classroom Classroom?    @relation(fields: [classroomId], references: [id])
  teacher  Teacher?     @relation(fields: [teacherId], references: [id])

  @@unique([orgId, day, period])
  @@index([orgId])
  @@index([teacherId])
  @@index([classroomId])
  @@index([orgId, classroomId])
  @@index([orgId, subject])
}

// Audit log for compliance and security tracking
model AuditLog {
  id            String    @id @default(cuid())
  action        String    // Type of action performed
  userId        String?   // Who performed the action
  orgId         String?   // Which organization
  targetId      String?   // ID of the affected entity
  targetType    String?   // Type of entity (Student, User, etc.)
  details       Json?     // Additional details as JSON
  ipAddress     String?   // Client IP address
  userAgent     String?   // Client user agent
  status        String    // SUCCESS or FAILURE
  errorMessage  String?   // Error message if failed
  createdAt     DateTime  @default(now())

  @@index([action])
  @@index([userId])
  @@index([orgId])
  @@index([targetId])
  @@index([targetType])
  @@index([status])
  @@index([createdAt])
  @@index([orgId, createdAt])
  @@index([action, createdAt])
}
